# ---------------------------------------------------------------------------
# GT Factory OS — Portal (.env.example)
#
# Copy to .env.local (gitignored) for local dev.
#
# Production values are configured via `vercel env add` on the Vercel project
# gt-factory-os-portal; this file does NOT carry production secrets.
# ---------------------------------------------------------------------------

# Supabase project URL (public, safe to commit as example).
# Anon key is published on the Supabase dashboard; it is RLS-scoped and is
# intended to be embedded in public web clients. Do NOT paste the service role
# key here.
NEXT_PUBLIC_SUPABASE_URL=https://rvadsozabmxkkrktwgnv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste from gt-factory-os/.env SUPABASE_ANON_KEY>

# GT Factory OS API base URL. Production API is deployed on Railway.
# For local dev against a local API run, set to http://localhost:3333.
NEXT_PUBLIC_API_BASE=https://gt-factory-os-api-production.up.railway.app

# Dev-shim feature flag. When "true", the portal uses the fake-session flow
# (FAKE_USERS in src/lib/auth/fake-auth.ts). When "false" or unset, the portal
# uses the real Supabase magic-link flow.
#
# Production Vercel value: false
# Local dev default:       true (enables existing Playwright real-HTTP suites)
NEXT_PUBLIC_ENABLE_DEV_SHIM_AUTH=false

# ---------------------------------------------------------------------------
# Legacy per-form API bases (local dev only)
#
# Gate-3 and Gate-5 proxy routes under src/app/api/**/route.ts currently read
# these to locate a local Fastify dev server. They are unused in production
# because NEXT_PUBLIC_API_BASE (above) is the single production target.
# ---------------------------------------------------------------------------
# GOODS_RECEIPTS_API_BASE=http://localhost:3333
# WASTE_ADJUSTMENTS_API_BASE=http://localhost:3333
# PHYSICAL_COUNT_API_BASE=http://localhost:3333
# FORECASTS_API_BASE=http://localhost:3333
# PLANNING_API_BASE=http://localhost:3333
# EXCEPTIONS_API_BASE=http://localhost:3333
